VertexlitGeneric
{
	$basetexture	"models/weapons/arc9/gst/gst_gm6/gm6"
	$bumpmap	"models/weapons/arc9/gst/gst_gm6/gm6_n"
	"$phongexponenttexture" "models/weapons/arc9/gst/gst_gm6/gm6_s"
	"$envmapmask" "models/weapons/arc9/gst/gst_gm6/gm6_s"
	$normalmapalphaenvmapmask 1
	
	"$blendtintbybasealpha" "1"
	"$phong" "1"
	"$phongboost" "1"
	"$phongalbedotint" "2"
	"$PhongFresnelRanges" "[ 2 5 4 ]"
	"$envmap" "env_cubemap"
//	"$basemapalphaenvmapmask" "1"
	$envmapfresnel "0.01"
	$envmaptint "[ .01 .01 .01 ]"

	"$nocull" "1"

	$detailblendmode 4
	$detailblendfactor 0.9
	$detail "models/weapons/arc9/colors/black_detail"
	Proxies {
		CustomCamo {
			camoTexture $detail
			camoScale $detailscale
            blend $detailblendfactor
		}
	}
}