VertexlitGeneric
{
	$basetexture	"models/weapons/arc9/gst/gst_fp6/alpha"
	$bumpmap	"models/weapons/arc9/gst/gst_fp6/alpha_n"
	$normalmapalphaenvmapmask 1
	"$translucent" "1"
	
	"$blendtintbybasealpha" "1"
	"$phong" "1"
	"$phongboost" "1"
	"$phongalbedotint" "2"
	"$PhongFresnelRanges" "[ 2 5 4 ]"
	"$envmap" "env_cubemap"
//	"$basemapalphaenvmapmask" "1"
	$envmapfresnel "0.01"
	$envmaptint "[ .01 .01 .01 ]"

	"$nocull" "1"

	$detailblendmode 4
	$detailblendfactor 0.85
	$detail "models/weapons/arc9/colors/black_detail"
	Proxies {
		CustomCamo {
			camoTexture $detail
			camoScale $detailscale
            blend $detailblendfactor
		}
	}
}